// Тапсырманы сипаттайтын құрылым
struct Task {
    string name;           // Тапсырма атауы
    string priority;       // Маңыздылығы (Жоғары, Орташа, Төмен)
    bool isCompleted;      // Орындалу күйі
    int id;                // Бірегей идентификатор
    // Жаңа тапсырманы оңай жасауға арналған конструктор
    Task(int taskId, const string& taskName, const string& taskPriority) 
        : id(taskId), name(taskName), priority(taskPriority), isCompleted(false) {}
};

// Тапсырмаларды сақтауға арналған жаһандық вектор
vector<Task> taskList;
int nextId = 1; // ID генерациялауға арналған есептегіш

// Консольдегі мәтін түсін өзгерту функциясы
void setColor(int color) {
    HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);
    SetConsoleTextAttribute(hConsole, color);
}

